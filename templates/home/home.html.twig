{% extends 'base.html.twig' %}

{% block title %}Mes heures · Tempo{% endblock %}

{# Une ligne d'affectation projet : sert au rendu des lignes existantes et de
   prototype (réutilisé tel quel par le contrôleur Stimulus). #}
{% macro alloc_row(row) %}
    {% set selectedValue = row.project.vars.value %}
    {% set selectedProject = null %}
    {% for choice in row.project.vars.choices %}
        {% if choice.value == selectedValue %}{% set selectedProject = choice.data %}{% endif %}
    {% endfor %}
    <div class="ts-alloc-row" data-project-allocations-target="row">
        <div class="ts-alloc-fields">
            {# Select custom : aperçu icône + couleur dans le déclencheur et chaque
               option. Le select natif (masqué) porte la valeur soumise. #}
            <div class="ts-cselect" data-controller="project-select">
                {{ form_widget(row.project, {attr: {
                    'data-project-select-target': 'native',
                    class: 'ts-cselect-native',
                }}) }}
                <button type="button" class="ts-cselect-trigger inp"
                        data-project-select-target="trigger"
                        data-action="project-select#toggle keydown->project-select#triggerKeydown"
                        aria-haspopup="listbox" aria-expanded="false">
                    <span class="ts-cselect-value" data-project-select-target="value">
                        {% if selectedProject %}
                            {% include 'admin/_project_color.html.twig' with {color: selectedProject.color, icon: selectedProject.icon, size: 22} only %}
                            <span class="ts-cselect-option-name">{{ selectedProject.name }}</span>
                        {% else %}
                            <span class="ts-cselect-placeholder">{{ row.project.vars.placeholder }}</span>
                        {% endif %}
                    </span>
                    <svg class="ts-cselect-caret" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
                </button>
                <ul class="ts-cselect-menu" data-project-select-target="menu" role="listbox" hidden
                    data-action="keydown->project-select#menuKeydown">
                    {% for choice in row.project.vars.choices %}
                        {% set p = choice.data %}
                        <li class="ts-cselect-option {{ choice.value == selectedValue ? 'is-selected' : '' }}"
                            role="option" tabindex="-1"
                            data-value="{{ choice.value }}"
                            data-action="click->project-select#select"
                            aria-selected="{{ choice.value == selectedValue ? 'true' : 'false' }}">
                            {% include 'admin/_project_color.html.twig' with {color: p.color, icon: p.icon, size: 22} only %}
                            <span class="ts-cselect-option-name">{{ p.name }}</span>
                        </li>
                    {% endfor %}
                </ul>
            </div>
            <div class="ts-alloc-hours">
                {{ form_widget(row.hours) }}
                <span class="ts-alloc-unit">h</span>
            </div>
        </div>
        <button type="button" class="ts-alloc-remove" data-action="project-allocations#remove" aria-label="Retirer ce projet">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
        <div class="ts-alloc-row-errors">
            {{ form_errors(row.project) }}
            {{ form_errors(row.hours) }}
        </div>
    </div>
{% endmacro %}

{% block body %}
    {% import _self as ui %}
    {% set today = "now"|date("Y-m-d") %}
    {% set selectedKey = selectedDate|date("Y-m-d") %}

    {% set dowFr = {'Mon': 'Lun', 'Tue': 'Mar', 'Wed': 'Mer', 'Thu': 'Jeu', 'Fri': 'Ven', 'Sat': 'Sam', 'Sun': 'Dim'} %}
    {% set dowFrFull = {'Mon': 'lundi', 'Tue': 'mardi', 'Wed': 'mercredi', 'Thu': 'jeudi', 'Fri': 'vendredi', 'Sat': 'samedi', 'Sun': 'dimanche'} %}
    {% set monthFr = {'Jan': 'janvier', 'Feb': 'février', 'Mar': 'mars', 'Apr': 'avril', 'May': 'mai', 'Jun': 'juin', 'Jul': 'juillet', 'Aug': 'août', 'Sep': 'septembre', 'Oct': 'octobre', 'Nov': 'novembre', 'Dec': 'décembre'} %}
    {% set monthFrShort = {'Jan': 'janv.', 'Feb': 'févr.', 'Mar': 'mars', 'Apr': 'avr.', 'May': 'mai', 'Jun': 'juin', 'Jul': 'juil.', 'Aug': 'août', 'Sep': 'sept.', 'Oct': 'oct.', 'Nov': 'nov.', 'Dec': 'déc.'} %}

    <main class="ts-shell">
        {% include 'components/topbar.html.twig' with {active: 'home'} only %}

        {# Toute la vue semaine dans un turbo-frame : saisie et planification se
           mettent à jour sans recharger la page, grille / totaux / historique
           restent cohérents. `advance` garde l'URL à jour pour la navigation
           jour & semaine ; `display: contents` préserve la mise en page flex.
           Les flashes sont dans le frame pour rester visibles après extraction. #}
        <turbo-frame id="week-view" data-turbo-action="advance" style="display: contents;">
            {% include 'components/flashes.html.twig' only %}

        {# ---------- Hero ---------- #}
        <section class="ts-hero">
            <div class="ts-hero-eyebrow">Semaine {{ weekStart|date("W") }} · {{ weekStart|date("d") }} {{ monthFrShort[weekStart|date("M")] }} → {{ weekEnd|date("d") }} {{ monthFrShort[weekEnd|date("M")] }} {{ weekEnd|date("Y") }}</div>
            <div class="ts-hero-row">
                <h1 class="ts-hero-title">
                    <span class="num">{{ weekTotal|number_format(1, ',', ' ') }}</span><em>h</em>
                    {% if weeklyTarget %}
                        <span class="text-small-font text-base num"> / {{ weeklyTarget|number_format(1, ',', ' ') }}h</span>
                    {% endif %}
                </h1>
                <div class="ts-hero-metrics">
                    {% if weeklyProgress is not null %}
                        <div>
                            <span class="ts-metric-k">Progression</span>
                            <span class="ts-metric-v num">{{ weeklyProgress }}%</span>
                        </div>
                    {% endif %}
                    <div>
                        <span class="ts-metric-k">Jours saisis</span>
                        <span class="ts-metric-v num">{{ daysWorked }} / {{ app.user.workingDaysPerWeek }}</span>
                    </div>
                    <div>
                        <span class="ts-metric-k">Heures sup.</span>
                        <span class="ts-metric-v num {{ overtimeHours > 0 ? 'is-positive' : '' }}">
                            {{ overtimeHours|number_format(1, ',', ' ') }}h
                        </span>
                    </div>
                    <div>
                        <span class="ts-metric-k">Cumul global</span>
                        <span class="ts-metric-v num">{{ grandTotal|number_format(1, ',', ' ') }}h</span>
                    </div>
                </div>
            </div>
        </section>

        {# ---------- Week navigation ---------- #}
        {% include 'components/week_nav.html.twig' with {weekStart: weekStart, contractStart: app.user.contractStartDate} only %}

        {# ---------- Submit week banner ---------- #}
        {% if not is_granted('ROLE_ADMIN') and weekSubmittableCount > 0 %}
            <section class="ts-weeksubmit">
                <div class="ts-weeksubmit-text">
                    <span class="ts-weeksubmit-count num">{{ weekSubmittableCount }}</span>
                    <span class="ts-weeksubmit-label">{{ weekSubmittableCount > 1 ? 'entrées à soumettre' : 'entrée à soumettre' }} pour validation</span>
                </div>
                <form action="{{ path('app_week_submit') }}" method="post">
                    <input type="hidden" name="week" value="{{ weekIso }}">
                    <input type="hidden" name="_token" data-controller="csrf-protection" value="{{ csrf_token('submit_week_' ~ app.user.id) }}">
                    <button type="submit" class="btn-submit">
                        <span>Soumettre la semaine</span>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                    </button>
                </form>
            </section>
        {% endif %}

        {# ---------- Weekly grid ---------- #}
        <div class="ts-week-scroll">
        <section class="ts-week">
            {% for cell in weekCells %}
                {% set dayDate = cell.date %}
                {% set dayKey = dayDate|date("Y-m-d") %}
                {% set entry = cell.entry %}
                {% set virtual = cell.virtualEntry %}
                {% set isSelected = dayKey == selectedKey %}
                {% set displayEntry = entry ?? virtual %}
                {% set typeVal = displayEntry ? displayEntry.dayType.value : null %}

                {% set variant = '' %}
                {% if cell.isBeforeContract %}
                    {% set variant = 'is-locked' %}
                {% elseif entry is null and virtual is not null %}
                    {% set variant = 'is-suggested is-remote' %}
                {% elseif typeVal == 'worked' %}
                    {% set variant = 'is-worked' %}
                {% elseif typeVal == 'remote' %}
                    {% set variant = 'is-remote' %}
                {% elseif typeVal == 'pto' %}
                    {% set variant = 'is-pto' %}
                {% elseif typeVal == 'uto' %}
                    {% set variant = 'is-uto' %}
                {% elseif typeVal == 'off' %}
                    {% set variant = 'is-off' %}
                {% endif %}

                {% set badge = '' %}
                {% if typeVal == 'remote' %}{% set badge = 'TT' %}
                {% elseif typeVal == 'pto' %}{% set badge = 'Congé' %}
                {% elseif typeVal == 'uto' %}{% set badge = 'Sans solde' %}
                {% elseif typeVal == 'off' %}{% set badge = 'Off' %}
                {% endif %}

                {% set classes = ['ts-day', variant] %}
                {% if displayEntry is null %}{% set classes = classes|merge(['is-empty']) %}{% endif %}
                {% if cell.isToday %}{% set classes = classes|merge(['is-today']) %}{% endif %}
                {% if isSelected %}{% set classes = classes|merge(['is-selected']) %}{% endif %}
                {% if cell.isFuture %}{% set classes = classes|merge(['is-future']) %}{% endif %}

                {% set classAttr = classes|filter(c => c != '')|join(' ') %}

                {% if cell.isBeforeContract %}
                    <span class="{{ classAttr }}" aria-disabled="true">
                        <div class="ts-day-head">
                            <span class="ts-day-dow">{{ dowFr[dayDate|date("D")] }}</span>
                            <span class="ts-day-num">{{ dayDate|date("d") }}</span>
                        </div>
                        <div class="ts-day-hours">—</div>
                        <div class="ts-day-status">Avant contrat</div>
                    </span>
                {% else %}
                    <a href="{{ path('app_home', {date: dayKey}) }}" class="{{ classAttr }}">
                        <div class="ts-day-head">
                            <span class="ts-day-dow">{{ dowFr[dayDate|date("D")] }}</span>
                            <span class="ts-day-num">{{ dayDate|date("d") }}</span>
                        </div>

                        {% if displayEntry %}
                            <div class="ts-day-hours">{{ displayEntry.hoursWorked|number_format(1, ',', ' ') }}h</div>
                        {% else %}
                            <div class="ts-day-hours">—</div>
                        {% endif %}

                        {% if badge %}
                            <span class="ts-day-badge">{{ badge }}</span>
                        {% elseif entry %}
                            <div class="ts-day-status">{{ entry.status.label }}</div>
                        {% elseif virtual %}
                            <div class="ts-day-status">Suggéré</div>
                        {% endif %}
                    </a>
                {% endif %}
            {% endfor %}
        </section>
        </div>

        {# ---------- Form + Recent ---------- #}
        <section class="ts-cols">
            {# Form card #}
            <div class="ts-card">
                <div>
                    <div class="ts-card-eyebrow">
                        {% if isReadOnly %}Entrée verrouillée
                        {% elseif isPlannedNonWork %}Jour planifié
                        {% elseif isEdit %}Modifier l’entrée
                        {% else %}Nouvelle entrée{% endif %}
                    </div>
                    <h2 class="ts-card-title">{{ dowFrFull[selectedDate|date("D")]|capitalize }} {{ selectedDate|date("d") }} {{ monthFr[selectedDate|date("M")] }} {{ selectedDate|date("Y") }}</h2>
                    <p class="ts-card-sub">
                        {% if isReadOnly %}
                            Statut : <strong>{{ currentEntry.status.label }}</strong>. Vous ne pouvez plus modifier cette entrée tant qu'elle n'est pas renvoyée pour révision par un admin.
                        {% elseif isPlannedNonWork %}
                            Cette journée est planifiée comme <strong>{{ currentEntry.dayType.label }}</strong>.
                            Supprimez-la pour la rouvrir à la saisie.
                        {% elseif isEdit %}
                            Vous pouvez ajuster les horaires, soumettre ou supprimer cette entrée.
                        {% else %}
                            Saisissez vos horaires pour cette journée.
                        {% endif %}
                    </p>
                </div>

                {% if isReadOnly %}
                    <div class="flex flex-col gap-3">
                        <div class="ts-planned-card ts-planned-locked">
                            <div class="flex items-center justify-between gap-3 flex-wrap">
                                <span class="ts-row-badge ts-badge-{{ currentEntry.status.value == 'approved' ? 'approved' : 'submitted' }}">{{ currentEntry.status.label }}</span>
                                <span class="num text-base">{{ currentEntry.hoursWorked|number_format(1, ',', ' ') }}h</span>
                            </div>
                            {% if currentEntry.dayType.value == 'worked' and currentEntry.startTime and currentEntry.endTime %}
                                <p class="text-[13px] text-small-font m-0">
                                    {{ currentEntry.startTime|date('H:i') }} → {{ currentEntry.endTime|date('H:i') }}
                                    {% if currentEntry.breakDuration %} · pause {{ currentEntry.breakDuration }}min{% endif %}
                                </p>
                            {% else %}
                                <p class="text-[13px] text-small-font m-0">{{ currentEntry.dayType.label }}</p>
                            {% endif %}
                            {% if currentEntry.note %}
                                <p class="text-[13px] text-dark-font m-0">{{ currentEntry.note }}</p>
                            {% endif %}
                            {% include 'home/_allocations.html.twig' with {entry: currentEntry} only %}
                        </div>
                        {% if currentEntry.status.canBeUnsubmittedByUser and not is_granted('ROLE_ADMIN') %}
                            <form action="{{ path('app_time_entry_unsubmit', {id: currentEntry.id}) }}" method="post" class="inline">
                                <input type="hidden" name="_token" data-controller="csrf-protection" value="{{ csrf_token('unsubmit_entry_' ~ currentEntry.id) }}">
                                <button type="submit" class="link-q">← Retirer ma soumission</button>
                            </form>
                        {% endif %}
                    </div>
                {% elseif isPlannedNonWork %}
                    <div class="flex flex-col gap-3">
                        <div class="ts-planned-card ts-planned-{{ currentEntry.dayType.value }}">
                            <div class="flex items-center justify-between gap-3 flex-wrap">
                                <span class="ts-day-badge">{{ currentEntry.dayType.label }}</span>
                                {% if currentEntry.status.value != 'draft' %}
                                    <span class="ts-row-badge ts-badge-{{ currentEntry.status.value == 'approved' ? 'approved' : (currentEntry.status.value == 'submitted' ? 'submitted' : (currentEntry.status.value == 'self_tracked' ? 'self' : 'review')) }}">{{ currentEntry.status.label }}</span>
                                {% endif %}
                            </div>
                            {% if currentEntry.note %}
                                <p class="text-[13px] text-small-font mt-2 m-0">{{ currentEntry.note }}</p>
                            {% endif %}
                        </div>
                        <form action="{{ path('app_time_entry_delete', {id: currentEntry.id}) }}" method="post"
                              onsubmit="return confirm('Supprimer cette planification ?');">
                            <input type="hidden" name="_token" data-controller="csrf-protection" value="{{ csrf_token('delete_entry_' ~ currentEntry.id) }}">
                            <button type="submit" class="link-q">Supprimer cette planification</button>
                        </form>
                    </div>
                {% else %}
                    {{ form_start(timeEntryForm, {attr: {class: 'flex flex-col gap-4', 'data-controller': 'remote-toggle'}}) }}
                        {% if not timeEntryForm.vars.valid %}
                            <div class="flash flash-error">
                                {{ form_errors(timeEntryForm) }}
                            </div>
                        {% endif %}

                        {{ form_row(timeEntryForm.date) }}

                        <label class="ts-toggle">
                            {{ form_widget(timeEntryForm.isRemote, {attr: {'data-remote-toggle-target': 'checkbox', 'data-action': 'change->remote-toggle#apply'}}) }}
                            <span class="ts-toggle-track" aria-hidden="true"><span class="ts-toggle-dot"></span></span>
                            <span class="ts-toggle-label">{{ timeEntryForm.isRemote.vars.label }}</span>
                        </label>

                        <div data-remote-toggle-target="times" class="ts-form-times flex flex-col gap-4">
                            <div class="field-row">
                                {{ form_row(timeEntryForm.startTime) }}
                                {{ form_row(timeEntryForm.endTime) }}
                            </div>
                            {{ form_row(timeEntryForm.breakDuration) }}
                        </div>

                        {{ form_row(timeEntryForm.note) }}

                        {# ---------- Affectation de projets ----------
                           Facultatif. Disponible pour les jours travaillés et le
                           télétravail (heures > 0). #}
                        <div class="ts-alloc-section"
                             data-controller="project-allocations"
                             data-project-allocations-index-value="{{ timeEntryForm.projectAllocations|length }}"
                             data-project-allocations-prototype-value="{{ ui.alloc_row(timeEntryForm.projectAllocations.vars.prototype)|e('html_attr') }}">
                            <div class="ts-alloc-head">
                                <span class="ts-card-eyebrow">Projets de la journée</span>
                                <span class="ts-alloc-hint">Facultatif — répartissez vos heures sans dépasser le total du jour.</span>
                            </div>

                            {{ form_errors(timeEntryForm.projectAllocations) }}

                            <div data-project-allocations-target="list" class="ts-alloc-list">
                                {% for allocation in timeEntryForm.projectAllocations %}
                                    {{ ui.alloc_row(allocation) }}
                                {% endfor %}
                            </div>

                            <p data-project-allocations-target="empty" class="ts-alloc-empty">Aucun projet affecté.</p>

                            <button type="button" class="link-q ts-alloc-add" data-action="project-allocations#add">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                                Ajouter un projet
                            </button>
                        </div>

                        <div class="flex items-center justify-between gap-3 mt-2 flex-wrap">
                            <button type="submit" class="btn-submit">
                                <span>{{ isEdit ? 'Mettre à jour' : 'Enregistrer la journée' }}</span>
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                            </button>
                            {% if isEdit and currentEntry and currentEntry.status.value != 'draft' %}
                                <span class="ts-row-badge ts-badge-{{ currentEntry.status.value == 'to_be_reviewed' ? 'review' : (currentEntry.status.value == 'submitted' ? 'submitted' : (currentEntry.status.value == 'self_tracked' ? 'self' : 'approved')) }}">{{ currentEntry.status.label }}</span>
                            {% endif %}
                        </div>
                    {{ form_end(timeEntryForm, {render_rest: false}) }}

                    {% if isEdit and currentEntry %}
                        <form action="{{ path('app_time_entry_delete', {id: currentEntry.id}) }}" method="post"
                              onsubmit="return confirm('Supprimer cette entrée ?');" class="mt-2">
                            <input type="hidden" name="_token" data-controller="csrf-protection" value="{{ csrf_token('delete_entry_' ~ currentEntry.id) }}">
                            <button type="submit" class="link-q">Supprimer cette entrée</button>
                        </form>
                    {% endif %}
                {% endif %}
            </div>

            {# Recent entries card #}
            <div class="ts-card">
                <div>
                    <div class="ts-card-eyebrow">Historique récent</div>
                    <h2 class="ts-card-title">10 dernières entrées</h2>
                </div>

                {% if recentEntries is empty %}
                    <div class="ts-empty">Aucune entrée pour le moment.<br>Saisissez votre première journée.</div>
                {% else %}
                    <div class="ts-list">
                        {% for entry in recentEntries %}
                            <div class="ts-row">
                                <a href="{{ path('app_home', {date: entry.date|date('Y-m-d')}) }}" class="ts-row-date no-underline">
                                    <span class="ts-row-date-strong">{{ entry.date|date('d/m') }}</span>
                                    <span class="block opacity-60 text-[11px]">{{ entry.date|date('Y') }}</span>
                                </a>
                                <div class="ts-row-meta">
                                    {% if entry.dayType.value == 'worked' and entry.startTime and entry.endTime %}
                                        <span>{{ entry.startTime|date('H:i') }} → {{ entry.endTime|date('H:i') }}
                                            {% if entry.breakDuration %}· pause {{ entry.breakDuration }}min{% endif %}
                                        </span>
                                    {% else %}
                                        <span>{{ entry.dayType.label }}</span>
                                    {% endif %}
                                    {% if entry.note %}<span class="ts-row-note">{{ entry.note }}</span>{% endif %}
                                    {% include 'home/_allocations.html.twig' with {entry: entry} only %}
                                </div>
                                <div class="ts-row-hours">{{ entry.hoursWorked|number_format(1, ',', ' ') }}h</div>
                                <div>
                                    {% set s = entry.status.value %}
                                    <span class="ts-row-badge ts-badge-{{ s == 'draft' ? 'draft' : (s == 'submitted' ? 'submitted' : (s == 'approved' ? 'approved' : (s == 'self_tracked' ? 'self' : 'review'))) }}">
                                        {{ entry.status.label }}
                                    </span>
                                </div>
                                <div class="ts-row-actions">
                                    {% if entry.status.isEditableByUser %}
                                        <form action="{{ path('app_time_entry_delete', {id: entry.id}) }}" method="post"
                                              onsubmit="return confirm('Supprimer cette entrée ?');" class="inline">
                                            <input type="hidden" name="_token" data-controller="csrf-protection" value="{{ csrf_token('delete_entry_' ~ entry.id) }}">
                                            <button type="submit" class="ts-icon-btn" title="Supprimer">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2m3 0v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/></svg>
                                            </button>
                                        </form>
                                    {% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </section>

        {# ---------- Planning panel ---------- #}
        {% include 'components/planning_form.html.twig' with {planningForm: planningForm} only %}
        </turbo-frame>
    </main>
{% endblock %}
