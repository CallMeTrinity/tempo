{% extends 'base.html.twig' %}

{% block title %}Connexion · Tempo{% endblock %}

{% block body %}
    <main class="auth-page">
        {% include 'components/auth_panel.html.twig' with {
            eyebrow: 'N° 01 — Retour',
            number: '37.5',
            unit: 'heures',
            lede: "Reprenez là où vous en étiez. Votre semaine en cours vous attend, prête à être pointée et soumise à validation."
        } only %}

        <section class="form-side">
            <header class="form-side-top">
                <a href="/" class="back-link">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 6l-6 6 6 6"/></svg>
                    Accueil
                </a>
                <div class="lang">FR · <span class="text-small-font">EN</span></div>
            </header>

            <div class="form-wrap">
                <form method="post" class="form-card">
                    {% if error %}
                        <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                    {% endif %}

                    {% if app.user %}
                        <div class="alert">
                            Connecté en tant que {{ app.user.userIdentifier }}.
                            <a href="{{ logout_path() }}" class="link-q">Se déconnecter</a>
                        </div>
                    {% endif %}

                    <div class="form-head">
                        <div class="eyebrow">Connexion</div>
                        <h1 class="form-h1">Bon retour.</h1>
                        <p class="form-sub">Saisissez vos identifiants pour reprendre votre semaine en cours.</p>
                    </div>

                    <div class="divider"><span>identifiez-vous</span></div>

                    <div class="field">
                        <label for="username" class="lbl">Nom d'utilisateur</label>
                        <input type="text" value="{{ last_username }}" name="_username" id="username"
                               class="inp" placeholder="prenom.n"
                               autocomplete="username" required autofocus>
                    </div>

                    <div class="field">
                        <div class="lbl-row">
                            <label for="password" class="lbl">Mot de passe</label>
                            <a href="{{ path('app_forgot_password_request') }}" class="link-q">Mot de passe oublié ?</a>
                        </div>
                        <input type="password" name="_password" id="password"
                               class="inp" placeholder="••••••••••"
                               autocomplete="current-password" required>
                    </div>

                    <label class="check">
                        <input type="checkbox" name="_remember_me" checked>
                        <span class="check-box">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5l4 4 10-10"/></svg>
                        </span>
                        <span>Rester connecté pendant 30 jours</span>
                    </label>

                    <input type="hidden" name="_csrf_token" data-controller="csrf-protection"
                           value="{{ csrf_token('authenticate') }}">

                    <button class="btn-submit" type="submit">
                        <span>Se connecter</span>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                    </button>

                    <div class="form-foot">
                        Pas encore de compte ?
                        <a href="{{ path('app_register') }}" class="link-swap">Créer un compte</a>
                    </div>
                </form>
            </div>

            <footer class="form-side-foot">
                <span>© 2026 Tempo</span>
                <span class="dot">·</span>
                <a href="#">Aide</a>
                <span class="dot">·</span>
                <a href="#">Confidentialité</a>
            </footer>
        </section>
    </main>
{% endblock %}
