{# Topbar partagée pour les pages authentifiées.
   `active` est la clé de l'item courant : 'home' | 'month' | 'profile' | 'admin'.
   Le compte admin n'est pas un employé : on n'affiche que la nav admin. #}
{% set isAdmin = is_granted('ROLE_ADMIN') %}
{% set active = active|default('') %}
{% set currentRoute = app.request.attributes.get('_route') %}
{% if active == '' %}
    {% if currentRoute starts with 'app_admin_' %}
        {% set active = 'admin' %}
    {% elseif currentRoute starts with 'app_profile_' %}
        {% set active = 'profile' %}
    {% elseif currentRoute in ['app_month', 'app_month_current'] %}
        {% set active = 'month' %}
    {% else %}
        {% set active = 'home' %}
    {% endif %}
{% endif %}

{% set brandPath = isAdmin ? path('app_admin_index') : path('app_home') %}

<header class="ts-topbar">
    <a href="{{ brandPath }}" class="ts-brand">
        <span class="ts-brand-mark">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        </span>
        <span class="ts-brand-text">Tempo</span>
    </a>

    <nav class="ts-nav">
        {% if isAdmin %}
            <a href="{{ path('app_admin_index') }}" class="ts-nav-link is-active">Administration</a>
        {% else %}
            <a href="{{ path('app_home') }}" class="ts-nav-link {{ active == 'home' ? 'is-active' : '' }}">Semaine</a>
            <a href="{{ path('app_month_current') }}" class="ts-nav-link {{ active == 'month' ? 'is-active' : '' }}">Mois</a>
            <a href="{{ path('app_profile_index') }}" class="ts-nav-link {{ active == 'profile' ? 'is-active' : '' }}">Profil</a>
        {% endif %}
    </nav>

    <div class="ts-userbox">
        <span class="ts-avatar" title="{{ app.user.fullName ?? app.user.userIdentifier }}">{{ app.user.initials }}</span>
        <span class="dot">·</span>
        <a href="{{ logout_path() }}" class="link-q">Se déconnecter</a>
    </div>
</header>

{% if app.user and not isAdmin and not app.user.isEmailVerified %}
    {% set cooldown = app.user.verificationEmailCooldownRemaining %}
    <div class="ts-verify-banner" role="status"
         style="display:flex;flex-wrap:wrap;align-items:center;gap:10px;justify-content:center;background:#fff7ed;border:1px solid #fed7aa;color:#9a3412;border-radius:10px;padding:10px 16px;margin:0 0 16px;font-size:13px;">
        <span>Confirmez votre adresse email pour sécuriser votre compte. Vérifiez votre boîte mail.</span>
        <form method="post" action="{{ path('app_verify_resend') }}" class="inline"
              data-controller="cooldown" data-cooldown-remaining-value="{{ cooldown }}">
            <input type="hidden" name="_token" data-controller="csrf-protection" value="{{ csrf_token('resend_verify_email') }}">
            <button type="submit" class="link-q" style="font-weight:600;"
                    data-cooldown-target="button" {{ cooldown > 0 ? 'disabled' : '' }}>
                <span data-cooldown-target="label">
                    {%- if cooldown > 0 -%}
                        Mail envoyé · renvoyer dans {{ (cooldown // 60) ~ ':' ~ ('%02d'|format(cooldown % 60)) }}
                    {%- else -%}
                        Renvoyer l'email
                    {%- endif -%}
                </span>
            </button>
        </form>
    </div>
{% endif %}
