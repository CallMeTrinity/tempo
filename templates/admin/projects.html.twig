{% extends 'base.html.twig' %}

{% block title %}Admin · Projets · Tempo{% endblock %}

{% block body %}
    <main class="ts-shell">
        {% include 'components/topbar.html.twig' with {active: 'admin'} only %}
        {% include 'components/flashes.html.twig' only %}

        <section class="ts-hero">
            <div class="ts-hero-eyebrow">Administration · Projets</div>
            <h1 class="ts-hero-title"><span>Projets d'équipe</span></h1>
        </section>

        {% include 'admin/_subnav.html.twig' with {active: 'projects', projectsCount: projects|length} only %}

        <section class="ts-card">
            <div class="flex items-center justify-between gap-4 flex-wrap">
                <div>
                    <div class="ts-card-eyebrow">Projets partagés</div>
                    <h2 class="ts-card-title">{{ projects|length }} projet{{ projects|length > 1 ? 's' : '' }}</h2>
                    <p class="ts-card-sub">Projets visibles par les membres associés pour la saisie d'heures.</p>
                </div>
                <a href="{{ path('app_admin_project_new') }}" class="btn-submit">
                    <span>Nouveau projet</span>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                </a>
            </div>

            {% if projects is empty %}
                <div class="ts-empty">Aucun projet d'équipe. Créez-en un pour commencer.</div>
            {% else %}
                <div class="ts-scroll-x">
                    <div class="ts-table ts-table-projects">
                        <div class="ts-table-head">
                            <div>Projet</div>
                            <div class="ts-table-num">Membres</div>
                            <div>Statut</div>
                            <div></div>
                        </div>

                        {% for project in projects %}
                            <div class="ts-table-row">
                                <div class="ts-table-user">
                                    {% include 'admin/_project_color.html.twig' with {color: project.color, icon: project.icon, size: 32} only %}
                                    <div class="flex flex-col min-w-0">
                                        <span class="ts-table-user-name">{{ project.name }}</span>
                                        {% if project.description %}
                                            <span class="ts-table-user-meta">{{ project.description }}</span>
                                        {% endif %}
                                    </div>
                                </div>
                                <div class="ts-table-num num">{{ project.members|length }}</div>
                                <div>
                                    {% if project.isActive %}
                                        <span class="ts-row-badge ts-badge-approved">Actif</span>
                                    {% else %}
                                        <span class="ts-row-badge ts-badge-draft">Inactif</span>
                                    {% endif %}
                                </div>
                                <div class="ts-table-actions">
                                    <form method="post" action="{{ path('app_admin_project_toggle', {id: project.id}) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('project_toggle_' ~ project.id) }}">
                                        <button type="submit" class="link-q">
                                            {{ project.isActive ? 'Désactiver' : 'Activer' }}
                                        </button>
                                    </form>
                                    <a class="link-q" href="{{ path('app_admin_project_edit', {id: project.id}) }}">Éditer →</a>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
        </section>
    </main>
{% endblock %}
